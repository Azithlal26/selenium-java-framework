<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="CrossBrowserSuite"
       parallel="tests"
       thread-count="3">

    <listeners>

        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>

        <listener class-name= "com.azith.framework.listeners.TestListener"/>

    </listeners>

    <test name="Chrome">

        <parameter
                name="browser"
                value="chrome"/>

        <classes>

            <class name=
                           "com.azith.framework.tests.LoginTest"/>

        </classes>

    </test>

    <test name="Edge">

        <parameter
                name="browser"
                value="edge"/>

        <classes>

            <class name=
                           "com.azith.framework.tests.LoginTest"/>

        </classes>

    </test>

    <test name="Firefox">

        <parameter
                name="browser"
                value="firefox"/>

        <classes>

            <class name=
                           "com.azith.framework.tests.LoginTest"/>

        </classes>

    </test>

</suite>